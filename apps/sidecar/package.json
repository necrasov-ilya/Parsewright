{
  "name": "@parsewright/sidecar",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@parsewright/capture": "workspace:*",
    "@parsewright/core": "workspace:*",
    "@parsewright/model-gateway": "workspace:*",
    "@parsewright/storage": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
